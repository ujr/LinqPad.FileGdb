    <mxGraphModel dx="1426" dy="961" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="jb_JZcYhICN6SN-B9wHY-1" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Shape classes&lt;/h1&gt;&lt;p&gt;When a shape buffer or a geometry blob is unpacked, a specific subtype of the Shape class is created. They correspond to Esri&#39;s “high-level” geometries; this library has no explicit representation of the constituent geometries, such as paths and rings. &lt;br&gt;MultiPatches and GeometryBags are not (yet) implemented.&lt;/p&gt;" vertex="1">
          <mxGeometry height="130" width="350" x="80" y="80" as="geometry" />
        </mxCell>
        <mxCell id="jb_JZcYhICN6SN-B9wHY-2" parent="1" style="text;html=1;strokeColor=#666666;fillColor=#f5f5f5;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=4;spacingTop=2;fontColor=#333333;" value="&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;i&gt;Shape&lt;/i&gt;&lt;/font&gt;&lt;/b&gt;&amp;nbsp;(abstract)&lt;br&gt;GeometryType: enum&lt;div&gt;Flags: ShapeFlags enum&lt;br&gt;&lt;div&gt;HasZ, HasM, HasID: bool&lt;br&gt;Box: BoxShape&lt;br&gt;IsEmpty: bool&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="100" width="180" x="510" y="100" as="geometry" />
        </mxCell>
        <mxCell id="jb_JZcYhICN6SN-B9wHY-3" parent="1" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=4;spacingTop=2;" value="&lt;font&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;NullShape&lt;/font&gt;&lt;/b&gt;&lt;span style=&quot;font-size: 13px&quot;&gt; (singleton)&lt;/span&gt;&lt;/font&gt;&lt;br&gt;GeometryType = Null&lt;div&gt;IsEmpty = true&lt;/div&gt;&lt;div&gt;Box = empty&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="80" y="280" as="geometry" />
        </mxCell>
        <mxCell id="jb_JZcYhICN6SN-B9wHY-4" parent="1" style="text;html=1;strokeColor=#6c8ebf;fillColor=#dae8fc;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=4;spacingTop=2;" value="&lt;font&gt;&lt;b&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;PointShape&lt;/font&gt;&lt;/b&gt;&lt;span style=&quot;font-size: 13px&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;br&gt;X, Y, Z, M: double&lt;div&gt;ID: int&lt;/div&gt;&lt;div&gt;IsEmpty = X or Y is NaN&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="160" x="280" y="280" as="geometry" />
        </mxCell>
        <mxCell id="jb_JZcYhICN6SN-B9wHY-5" parent="1" style="text;html=1;strokeColor=#d79b00;fillColor=#ffe6cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;spacingLeft=4;" value="&lt;b&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;GeometryType&lt;/font&gt;&lt;/b&gt; (enum)&lt;br&gt;Null = 0&lt;div&gt;Point = 1&lt;/div&gt;&lt;div&gt;Multipoint = 2&lt;/div&gt;&lt;div&gt;Polyline = 3&lt;/div&gt;&lt;div&gt;Polygon = 4&lt;/div&gt;&lt;div&gt;Envelope = 5 (box)&lt;/div&gt;&lt;div&gt;Any = 7&lt;/div&gt;&lt;div&gt;MultiPatch = 9&lt;/div&gt;&lt;div&gt;Bag = 17&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="150" x="930" y="100" as="geometry" />
        </mxCell>
        <mxCell id="jb_JZcYhICN6SN-B9wHY-6" parent="1" style="text;html=1;strokeColor=#d6b656;fillColor=#fff2cc;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;sketch=1;shadow=0;spacingLeft=2;spacingTop=2;" value="GeometryType is the “high level” type; the File Geodatabase only supports Null, Point, Multipoint, Polyline, Polygon, and MultiPatch. ArcObjects has types for the constituent geometries: Path, Ring, Line, CircularArc, Bezier3Curve, EllipticArc, TriangleStrip, TriangleFan, Ray, Sphere." vertex="1">
          <mxGeometry height="155" width="190" x="80" y="415" as="geometry" />
        </mxCell>
